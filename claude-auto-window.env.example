# Optional overrides for claude-auto-window.
#
# Config file: the script auto-loads $XDG_CONFIG_HOME/claude-auto-window/config
#   (usually ~/.config/claude-auto-window/config) for cron/manual runs. Copy the
#   uncommented lines below there. Env vars and CLI flags override the file.
# systemd: point EnvironmentFile at ~/.config/claude-auto-window/<profile>.env
#   instead — it is NOT shell-evaluated, so use absolute paths, no $HOME / ~.

# --- Cadence (daemon) ------------------------------------------------------
# The daemon does NOT poll continuously. When a window is open it sleeps until
# just after it expires (resets_at + POST_EXPIRY), wakes, sees it closed, fires.
# Wake this long after expiry before firing the next starter:
CLAUDE_AUTO_WINDOW_POST_EXPIRY_SECONDS=5
# INTERVAL is only the confirm-poll cadence: how often to re-check while waiting
# for the endpoint to reflect a just-opened window (it lags a few minutes).
CLAUDE_AUTO_WINDOW_INTERVAL_SECONDS=60
# Safety cap on any single sleep (guards against clock drift / suspend).
# Default 21600 (6h) lets a normal 5h window sleep in one go; lower it to
# re-verify more often on machines that suspend.
CLAUDE_AUTO_WINDOW_MAX_SLEEP_SECONDS=21600
# Random MIN..MAX wait before firing. Anti-stampede for many hosts/cron ticks;
# on a single daemon keep it small (or 0) so windows stay tight back-to-back.
CLAUDE_AUTO_WINDOW_JITTER_MIN_SECONDS=0
CLAUDE_AUTO_WINDOW_JITTER_MAX_SECONDS=180
# (cron ignores INTERVAL/MAX_SLEEP/POST_EXPIRY — its cadence is the crontab schedule.)

# --- Run behaviour ---------------------------------------------------------
# --once (and cron) exits early WITHOUT fetching while the stored resets_at is
# still in the future — so a per-minute cron only hits the endpoint near expiry.
# This is always on; there's nothing to configure.
# FORCE=1 makes `--run` fire even on an account with NO 5-hour window (the one
# safety check --run keeps). Off by default. No effect on --once / --daemon.
# CLAUDE_AUTO_WINDOW_FORCE=0

# After opening a window, the usage endpoint takes a few minutes to reflect it.
# During that lag it still reads "closed", so we suppress re-opening for this many
# seconds after a successful open (prevents the daemon re-firing during the lag).
# CLAUDE_AUTO_WINDOW_OPEN_COOLDOWN_SECONDS=900

# --- Circuit breaker (stop runaway loops) ----------------------------------
# If opens keep firing but never register a window (a fault, or pathological
# lag), stop after this many consecutive failures instead of looping forever.
# On trip: notify (below), write a persistent trip file, and refuse to run until
# `claude-auto-window --reset`. The daemon exits; cron runs no-op.
# CLAUDE_AUTO_WINDOW_MAX_FAILURES=3
# Shell command run once when the breaker trips. The message is on stdin AND in
# $CLAUDE_AUTO_WINDOW_MESSAGE. Examples:
#   Linux desktop: notify-send "claude-auto-window" "$CLAUDE_AUTO_WINDOW_MESSAGE"
#   Email:         mail -s "claude-auto-window tripped" you@example.com
#   ntfy:          curl -d "$CLAUDE_AUTO_WINDOW_MESSAGE" ntfy.sh/your-topic
#   macOS:         osascript -e "display notification \"$CLAUDE_AUTO_WINDOW_MESSAGE\""
# CLAUDE_AUTO_WINDOW_NOTIFY_CMD=
# Durable state dir for the breaker counter + trip file (survives reboot).
# CLAUDE_AUTO_WINDOW_STATE_DIR=$HOME/.local/state/claude-auto-window

# --- Profiles (default: let Claude Code resolve ~/.claude) -----------------
# Multi-account: ONE daemon/run can hold several logins open. List them here
# (comma- and/or space-separated names or absolute dirs), each serviced
# independently with per-profile failure isolation. Names: default | personal |
# work | <abs path>. This is the macOS win — one launchd plist, N subscriptions.
# CLAUDE_AUTO_WINDOW_PROFILES=personal work
#
# Legacy single-profile pin (still works; takes effect only when PROFILES is
# unset). Prefer PROFILES above, or passing --profile / --config-dir.
# CLAUDE_AUTO_WINDOW_CONFIG_DIR=/home/YOU/.claude-personal
#
# Precedence: CLI --profile/--config-dir (repeatable) > PROFILES > CONFIG_DIR >
# default. Duplicates (same resolved dir) are de-duplicated with a WARN.

# --- Balance gate (don't burn usage credits to anchor a window) ------------
# We only fire a starter when the STARTER's own model is still plan-covered.
# The starter is a tiny request on the cheapest model, so the governing plan
# bucket is the overall weekly cap (plus any model-scoped weekly cap matching
# the starter model — a Fable cap never blocks a haiku starter). Once that
# bucket hits this percent, the window is worthless anyway (no plan allowance to
# use inside it) and firing would spend credits, so we stand down. Lower it for
# a safety margin (e.g. 97).
# CLAUDE_AUTO_WINDOW_WEEKLY_MAX_PERCENT=100

# --- Starter behaviour -----------------------------------------------------
# The trivial prompt sent to open a window, and the reply we wait for.
# CLAUDE_AUTO_WINDOW_PROMPT=Reply with exactly: OK.
# CLAUDE_AUTO_WINDOW_EXPECT=OK.
# Reply occurrences required AFTER the prompt-echo lines are filtered out
# (claude runs directly in the pane, so there's no shell command-echo noise).
# CLAUDE_AUTO_WINDOW_EXPECT_COUNT=1
# Give up waiting for the reply after this many seconds (then tear down).
# CLAUDE_AUTO_WINDOW_REPLY_TIMEOUT_SECONDS=120
# When the stored OAuth access token has expired (>8h without any Claude
# activity), --once/the daemon self-heal by launching a bare claude session
# (no prompt — nothing sent or spent) that refreshes the token at startup,
# then re-check. Give up on that launch after this many seconds.
# CLAUDE_AUTO_WINDOW_REFRESH_TIMEOUT_SECONDS=45
# Model for the starter. Default is the "haiku" alias — the cheapest tier, and
# an alias always resolves to the LATEST model of that tier, so it survives
# version rotation. Set to a different alias/id, or "" for the account default.
# If the chosen model has been retired, the starter auto-retries on the default.
# CLAUDE_AUTO_WINDOW_MODEL=haiku
# Working dir for the interactive starter. Default: a stable per-user tmp dir
# ($TMPDIR/claude-auto-window-<uid>) — isolated from the work cwd, always empty,
# trusted once. Set this to pin a fixed location instead.
# CLAUDE_AUTO_WINDOW_STARTER_DIR=/home/YOU/.claude-auto-window

# --- Context stripping / cleanup -------------------------------------------
# LIGHT=1 (default) launches with --safe-mode --tools "" and trimmed prompt
# sections: no CLAUDE.md/memory, skills, hooks, MCP, plugins, agents, themes.
# Set to 0 to launch with your full config (heavier, more tokens).
# CLAUDE_AUTO_WINDOW_LIGHT=1
# The starter pins a session id and deletes its own transcript afterward so it
# doesn't clutter your conversation log. Set to 1 to keep it.
# CLAUDE_AUTO_WINDOW_KEEP_TRANSCRIPT=0

# --- Plumbing --------------------------------------------------------------
# Set when the claude binary isn't auto-discovered (command -v claude).
# CLAUDE_AUTO_WINDOW_CLAUDE_BIN=/home/YOU/.local/bin/claude
# Isolated tmux socket name (-L) so we never touch your real tmux server.
# CLAUDE_AUTO_WINDOW_TMUX_SOCKET=claude-auto-window
# Keys sent to accept the workspace-trust dialog (option 1 "Yes, proceed" is the
# highlighted default, so a bare Enter accepts it). Set e.g. "1 Enter" to be
# explicit. The starter dir is a dedicated dir you own, so auto-accept is safe.
# CLAUDE_AUTO_WINDOW_TRUST_KEYS=Enter
# Opt-in log file (stdout/stderr are always emitted for the journal).
# CLAUDE_AUTO_WINDOW_LOG=/home/YOU/.local/state/claude-auto-window/default.log
# QUIET=1 suppresses console output (logs only to the file above). Use for cron
# so it doesn't email on every run; leave off for systemd so the journal fills.
# CLAUDE_AUTO_WINDOW_QUIET=0

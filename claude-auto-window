#!/usr/bin/env zsh
# ============================================================================
# claude-auto-window — keep a Claude five-hour usage window perpetually open
# ============================================================================
# Goal: always have a 5-hour session window running, back to back, spending as
# few tokens as possible. When a window has lapsed, this opens a fresh one by
# driving a *real interactive* Claude Code session inside a throwaway tmux
# session — send one trivial prompt, wait for the reply, quit, tear the tmux
# session down. That single request is enough to anchor a new 5-hour window,
# so the next time you actually need Claude there is no cold-start wait.
#
# This is deliberately NOT the headless `claude -p` approach (see
# ../claude-auto-window-old for that Codex-authored variant) — we drive the
# genuine TUI path through tmux instead.
#
# The window check reads Claude Code's own OAuth usage endpoint directly (token
# resolution + fetch are inlined below) — no Anthropic API key required.
#
# ---------------------------------------------------------------------------
# Modes (pick one; --once is the default)
#   --run          Fire one starter now, no checks, no jitter. ("just do it")
#   --once         Check the window; only if none is open, jitter then fire.
#   --daemon       Loop --once at a fixed interval (systemd/launchd target).
#   --status       Print the current five-hour session state and exit.
#
# Profile
#   Default: let Claude Code resolve its own profile (~/.claude) — we never set
#   CLAUDE_CONFIG_DIR for the launch. Multi-profile support:
#     --config-dir PATH   explicit Claude profile dir (sets CLAUDE_CONFIG_DIR)
#     --profile NAME      default | personal | work | <abs path>
#
# Observability
#   Logs go to stdout/stderr always (journal-friendly). Opt in to a file with
#   --log PATH (or CLAUDE_AUTO_WINDOW_LOG). Nothing is written to a file unless
#   you ask for it.
#
# This file is both executable and source-able:
#   ./claude-auto-window --once
#   source ./claude-auto-window && claude-auto-window-once
# ============================================================================

typeset -g CLAUDE_AUTO_WINDOW_VERSION="1.0.0"

# ----------------------------------------------------------------------------
# Logging — stdout/stderr always; append to $CLAUDE_AUTO_WINDOW_LOG if opted in.
# ----------------------------------------------------------------------------
_caw_log() {
  emulate -L zsh
  local level="$1"; shift
  local line="$(date '+%Y-%m-%d %H:%M:%S') [$level] $*"
  # --quiet (CLAUDE_AUTO_WINDOW_QUIET=1) suppresses console output so a cron job
  # doesn't email on every routine run — logs still go to the file. systemd/
  # journal users leave it off so the journal keeps capturing output.
  if [[ "${CLAUDE_AUTO_WINDOW_QUIET:-0}" != 1 ]]; then
    if [[ "$level" == "ERROR" || "$level" == "WARN" ]]; then
      print -u2 -r -- "$line"
    else
      print -r -- "$line"
    fi
  fi
  [[ -n "${CLAUDE_AUTO_WINDOW_LOG:-}" ]] && print -r -- "$line" >> "$CLAUDE_AUTO_WINDOW_LOG"
}

_caw_validate_uint() {
  emulate -L zsh
  local name="$1" value="$2"
  if [[ "$value" != <-> ]]; then
    _caw_log ERROR "$name must be a non-negative integer (got: $value)"
    return 2
  fi
}

# ----------------------------------------------------------------------------
# Profile / binary resolution
# ----------------------------------------------------------------------------
# The dir used for the *window check* — always a concrete path (usage endpoint
# needs one). Defaults to ~/.claude even when we let Claude pick its own profile
# for the launch, because that is Claude Code's own default profile too.
_caw_check_dir() {
  local dir="${CLAUDE_AUTO_WINDOW_CONFIG_DIR:-${CLAUDE_CONFIG_DIR:-$HOME/.claude}}"
  print -r -- "${dir%/}"
}

# Whether to pin CLAUDE_CONFIG_DIR for the launch. Only when the operator
# explicitly selected a profile — otherwise we stay a transparent passthrough
# and Claude Code resolves ~/.claude on its own (mirrors claude-profile.zsh).
_caw_launch_profile_pinned() {
  [[ -n "${CLAUDE_AUTO_WINDOW_CONFIG_DIR:-${CLAUDE_CONFIG_DIR:-}}" ]]
}

_caw_resolve_claude_bin() {
  emulate -L zsh
  local configured="${CLAUDE_AUTO_WINDOW_CLAUDE_BIN:-}"
  if [[ -n "$configured" ]]; then
    [[ -x "$configured" ]] && { print -r -- "$configured"; return 0; }
    _caw_log ERROR "CLAUDE_AUTO_WINDOW_CLAUDE_BIN is not executable: $configured"
    return 2
  fi
  local found; found="$(whence -p claude 2>/dev/null)"
  [[ -n "$found" && -x "$found" ]] && { print -r -- "$found"; return 0; }
  local c
  for c in /opt/homebrew/bin/claude "$HOME/.local/bin/claude" \
           "$HOME/.npm-global/bin/claude" /usr/local/bin/claude /usr/bin/claude; do
    [[ -x "$c" ]] && { print -r -- "$c"; return 0; }
  done
  _caw_log ERROR "claude executable not found; set CLAUDE_AUTO_WINDOW_CLAUDE_BIN"
  return 2
}

# ----------------------------------------------------------------------------
# Usage endpoint — self-contained OAuth reader. We only need the raw usage JSON
# for the five-hour window check, so this is deliberately minimal: resolve the
# token Claude Code stored, GET the endpoint, return the raw response. No caching
# / display formatting (that belongs in a standalone `claude-usage` CLI; this is
# a different, programmatic use case).
#
# No Anthropic API key is used — the account's own OAuth login is read from
# <dir>/.credentials.json (Linux) or the macOS Keychain (service
# "Claude Code-credentials-<8 hex of sha256(abs dir)>", plus the legacy
# un-suffixed entry for ~/.claude). The freshest non-expired token wins.
# ----------------------------------------------------------------------------
_caw_resolve_token() {
  emulate -L zsh
  local dir="${1%/}"
  local -a blobs
  blobs=( "$(cat "$dir/.credentials.json" 2>/dev/null)" )
  if command -v security >/dev/null 2>&1; then
    local suffix
    suffix="$(printf '%s' "${dir:a}" | { shasum -a 256 2>/dev/null || sha256sum 2>/dev/null; } | cut -c1-8)"
    [[ -n "$suffix" ]] && blobs+=( "$(security find-generic-password -s "Claude Code-credentials-$suffix" -a "$USER" -w 2>/dev/null)" )
    [[ "$dir" == "$HOME/.claude" ]] && blobs+=( "$(security find-generic-password -s "Claude Code-credentials" -a "$USER" -w 2>/dev/null)" )
  fi
  local token="" best=-1 now_ms=$(( $(date +%s) * 1000 )) blob cand exp expired_only=0
  for blob in "${blobs[@]}"; do
    [[ -z "$blob" ]] && continue
    cand="$(jq -r '.claudeAiOauth.accessToken // empty' <<< "$blob" 2>/dev/null)"
    [[ -z "$cand" ]] && continue
    exp="$(jq -r '.claudeAiOauth.expiresAt // empty' <<< "$blob" 2>/dev/null)"
    [[ -n "$exp" ]] && (( exp <= now_ms )) && { expired_only=1; continue }  # expired
    [[ -z "$exp" ]] && exp=$now_ms                          # unknown expiry: usable, lowest priority
    (( exp > best )) && { best=$exp; token="$cand"; }
  done
  [[ -n "$token" ]] && { print -r -- "$token"; return 0; }
  # 4 = credentials exist but every access token has expired (access tokens live
  # ~8h; only a real claude launch refreshes them, via the stored refresh token).
  # Distinct from 1 (no credentials at all) so callers can fall through to firing
  # the starter — which refreshes the token as a side effect of sending.
  (( expired_only )) && return 4
  return 1
}

# Fresh raw usage JSON for a profile dir. Non-zero (and no output) on any
# failure so callers fall through to "unknown" — except 4 (access token expired,
# see _caw_resolve_token), which is propagated so callers can distinguish
# "can't authenticate until something sends" from network/API errors.
_caw_usage_json() {
  emulate -L zsh
  local dir="$1" token resp rc
  token="$(_caw_resolve_token "$dir")" || { rc=$?; (( rc == 4 )) && return 4; return 3; }
  resp="$(curl -s --connect-timeout 3 --max-time 6 \
    "https://api.anthropic.com/api/oauth/usage" \
    -H "Authorization: Bearer $token" \
    -H "anthropic-beta: oauth-2025-04-20" \
    -H "Content-Type: application/json" 2>/dev/null)" || return 3
  # Validate it's a real usage response, not an error/HTML/empty body.
  jq -e 'type == "object" and (.error == null) and ((.limits != null) or (.five_hour != null))' \
    <<< "$resp" >/dev/null 2>&1 || return 3
  print -r -- "$resp"
}

# Is a five-hour window currently open?
#   0 = open, 1 = closed, 2 = account has NO 5h window (API/usage-billed seat —
#   nothing to keep open), 3 = could not determine (network/API error),
#   4 = access token expired — state is unknowable until a claude launch
#   refreshes it, and the starter itself does exactly that, so callers should
#   treat this as "proceed to fire", not as an error. (This 4 is internal to
#   the session-check path; it is unrelated to the public exit code 4 =
#   "starter sent but no reply" from _caw_send_starter.)
#
# "Open" is decided SOLELY by `resets_at` being in the FUTURE. We deliberately do
# NOT consult the endpoint's `is_active` flag: it tracks *recent activity* (reads
# false on an open-but-idle window) and adds no coverage resets_at doesn't already
# give — and worse, a lingering `is_active` on a *past* resets_at could falsely
# read "open". resets_at is the one signal.
# On a confirmed-open return (0), this records profile + resets_at in the
# per-profile state file. That stored resets_at is the single source of truth for
# "when to act next": both the --once early-exit and the daemon's sleep read it.
# (It also self-documents which subscription the opaque <hash>.state belongs to.)
_caw_session_active() {
  emulate -L zsh
  local dir="$1" json has sess resets now rc
  json="$(_caw_usage_json "$dir")" || { rc=$?; (( rc == 4 )) && return 4; return 3; }
  [[ -n "$json" ]] || return 3
  # Does this account use the 5-hour session-window model at all? Pro/Max do;
  # API/usage-billed (Team/Enterprise/console) seats return no session limit.
  has="$(jq '[.limits[]? | select(.kind=="session")] | length' <<< "$json" 2>/dev/null)"
  [[ "$has" == <-> ]] || return 3
  (( has == 0 )) && return 2
  sess="$(jq -c 'first(.limits[]? | select(.kind=="session")) // {}' <<< "$json" 2>/dev/null)"
  resets="$(jq -r '.resets_at // ""' <<< "$sess" 2>/dev/null)"
  [[ -n "$resets" && "$resets" != "null" ]] || return 1   # no reset time → closed
  # resets_at and `date -u` are both UTC ISO-8601, so a lexical compare of the
  # fixed-width YYYY-MM-DDTHH:MM:SS prefix is a correct chronological compare.
  now="$(date -u +%Y-%m-%dT%H:%M:%S)"
  if [[ "${resets:0:19}" > "$now" ]]; then                # future → open
    _caw_state_set "$dir" profile "$dir"
    _caw_state_set "$dir" resets_at "$resets"
    return 0
  fi
  return 1                                                # null / past → closed
}

# Convert a UTC ISO-8601 timestamp (e.g. 2026-07-19T06:40:00.351+00:00) to epoch
# seconds. Tries BSD (macOS) then GNU (Linux) date. Non-zero if unparseable.
_caw_iso_to_epoch() {
  emulate -L zsh
  local dt="${1:0:19}" e                                  # YYYY-MM-DDTHH:MM:SS, UTC
  [[ -n "$dt" ]] || return 1
  e="$(date -u -j -f "%Y-%m-%dT%H:%M:%S" "$dt" +%s 2>/dev/null)" && { print -r -- "$e"; return 0; }
  e="$(date -u -d "${dt}Z" +%s 2>/dev/null)" && { print -r -- "$e"; return 0; }
  return 1
}

# Print a human status line.
_caw_status_line() {
  emulate -L zsh
  local dir="$1" rc json session open pct reset
  _caw_session_active "$dir"; rc=$?
  if (( rc == 3 )); then
    _caw_log ERROR "usage lookup failed for $dir"; return 1
  elif (( rc == 4 )); then
    print -r -- "profile=$dir five_hour=? (access token expired — --once/the daemon self-heal it with a bare claude launch; any claude use also refreshes it)"
    return 0
  elif (( rc == 2 )); then
    print -r -- "profile=$dir five_hour=n/a (no session window — API/usage-billed account?)"
    return 0
  fi
  (( rc == 0 )) && open=yes || open=no
  json="$(_caw_usage_json "$dir")"
  session="$(jq -c 'first(.limits[]? | select(.kind=="session")) // {}' <<< "$json" 2>/dev/null)"
  pct="$(jq -r '.percent // 0'       <<< "$session")"
  reset="$(jq -r '.resets_at // "?"' <<< "$session")"
  print -r -- "profile=$dir five_hour_open=$open percent=$pct resets_at=$reset"
  if _caw_breaker_tripped "$dir"; then
    print -r -- "  ⚠ DISABLED (sentinel present): $(_caw_state_file "$dir" tripped)"
    print -r -- "    reason: $(_caw_breaker_reason "$dir")"
    print -r -- "    re-enable: claude-auto-window --reset"
  fi
}

# Public: clear a tripped circuit breaker (and the failure counter) so the
# daemon/cron will resume opening windows.
claude-auto-window-reset() {
  emulate -L zsh
  local dir; dir="$(_caw_check_dir)"
  if _caw_breaker_tripped "$dir"; then
    _caw_breaker_clear "$dir"
    _caw_log INFO "Circuit breaker cleared for $dir — will resume on the next run"
  else
    _caw_breaker_clear "$dir"     # also clears any lingering counter
    _caw_log INFO "No tripped breaker for $dir; cleared any failure counter"
  fi
}

# Is a weekly allowance exhausted? (Don't burn a starter if capped.)
_caw_weekly_exhausted() {
  emulate -L zsh
  local json="$1"
  jq -e 'any(.limits[]?;
      ((.kind=="weekly_all" or .kind=="weekly_scoped")
       and (((.percent // 0) >= 100) or ((.severity // "normal") == "exceeded"))))' \
    <<< "$json" >/dev/null 2>&1
}

# Random integer in [0, max], preferring /dev/urandom, falling back to $RANDOM.
_caw_random() {
  emulate -L zsh
  local max="$1"
  (( max > 0 )) || { print 0; return; }
  local n=""
  if [[ -r /dev/urandom ]] && command -v od >/dev/null 2>&1; then
    n="$(od -An -N4 -tu4 /dev/urandom 2>/dev/null | tr -d '[:space:]')"
  fi
  [[ "$n" == <-> ]] || n="$RANDOM"
  print $(( n % (max + 1) ))
}

# Generate a lowercase UUID for --session-id (Linux /proc first, uuidgen else).
_caw_uuid() {
  emulate -L zsh
  local u=""
  if [[ -r /proc/sys/kernel/random/uuid ]]; then
    u="$(</proc/sys/kernel/random/uuid)"
  elif command -v uuidgen >/dev/null 2>&1; then
    u="$(uuidgen)"
  fi
  print -r -- "${u:l}"
}

# Delete the starter's own conversation transcript so it doesn't clutter the
# log. We pin a known session id, so the file is exactly <uuid>.jsonl under the
# active profile's projects/ tree (opt out with CLAUDE_AUTO_WINDOW_KEEP_TRANSCRIPT=1).
_caw_cleanup_transcript() {
  emulate -L zsh
  setopt local_options extended_glob null_glob
  local dir="$1" uuid="$2"
  [[ "${CLAUDE_AUTO_WINDOW_KEEP_TRANSCRIPT:-0}" == 1 ]] && return 0
  [[ -n "$uuid" && -d "$dir/projects" ]] || return 0
  local -a hits
  hits=( "$dir"/projects/**/"$uuid".jsonl )
  if (( ${#hits} )); then
    rm -f -- "${hits[@]}" 2>/dev/null
    _caw_log INFO "Removed starter transcript (${uuid}.jsonl)"
  fi
}

# ----------------------------------------------------------------------------
# Per-profile process lock — never run two starters for the same profile at once.
# ----------------------------------------------------------------------------
_caw_lock_path() {
  emulate -L zsh
  local dir="$1" suffix
  suffix="$(printf '%s' "${dir:a}" \
    | { shasum -a 256 2>/dev/null || sha256sum 2>/dev/null; } | cut -c1-8)"
  [[ -n "$suffix" ]] || suffix="default"
  print -r -- "${TMPDIR:-/tmp}/claude-auto-window.${suffix}.lock"
}

# Returns 0 (prints lock path) or 75 if another live process owns it.
_caw_acquire_lock() {
  emulate -L zsh
  local dir="$1" lock owner
  lock="$(_caw_lock_path "$dir")"
  if ! mkdir "$lock" 2>/dev/null; then
    [[ -r "$lock/pid" ]] && owner="$(<"$lock/pid")"
    if [[ "$owner" == <-> ]] && kill -0 "$owner" 2>/dev/null; then
      return 75
    fi
    rm -rf "$lock" 2>/dev/null
    mkdir "$lock" 2>/dev/null || return 75
  fi
  print -r -- "$$" > "$lock/pid"
  print -r -- "$lock"
}

_caw_release_lock() {
  emulate -L zsh
  [[ -n "$1" ]] && rm -rf "$1" 2>/dev/null
}

# ----------------------------------------------------------------------------
# Config & state locations (XDG):
#   config  ${XDG_CONFIG_HOME:-~/.config}/claude-auto-window/  — settings you set
#   state   ${XDG_STATE_HOME:-~/.local/state}/claude-auto-window/ — data we write
# A per-profile <hash>.state file (key=value) holds the failure counter and the
# open-timing; the disable sentinel (<hash>.tripped) is its own file so
# "present = disabled" stays a trivial touch/rm kill-switch. The process lock
# stays a transient tmp mkdir-lock (see _caw_lock_path).
# ----------------------------------------------------------------------------
_caw_config_dir() {
  emulate -L zsh
  print -r -- "${XDG_CONFIG_HOME:-$HOME/.config}/claude-auto-window"
}

# Auto-load a config file (cron/manual convenience) so settings need not be
# repeated as flags. Only fills CLAUDE_AUTO_WINDOW_* vars NOT already set, so the
# environment (systemd EnvironmentFile) and CLI flags still win. Values are
# literal, like a systemd EnvironmentFile — no shell quoting.
_caw_load_config() {
  emulate -L zsh
  local f="${CLAUDE_AUTO_WINDOW_CONFIG:-$(_caw_config_dir)/config}"
  [[ -r "$f" ]] || return 0
  local line key val
  while IFS= read -r line; do
    [[ -z "${line//[[:space:]]/}" || "${line##[[:space:]]#}" == \#* ]] && continue
    [[ "$line" == *=* ]] || continue
    key="${line%%=*}"; key="${key//[[:space:]]/}"
    [[ "$key" == CLAUDE_AUTO_WINDOW_* ]] || continue
    [[ -n "${(P)key+x}" ]] && continue          # already set by env/flags → keep it
    val="${line#*=}"
    typeset -gx "$key=$val"
  done < "$f"
}

_caw_state_dir() {
  emulate -L zsh
  print -r -- "${CLAUDE_AUTO_WINDOW_STATE_DIR:-${XDG_STATE_HOME:-$HOME/.local/state}/claude-auto-window}"
}

_caw_state_file() {   # $1 = config dir, $2 = short name (state | tripped)
  emulate -L zsh
  local dir="$1" name="$2" suffix
  suffix="$(printf '%s' "${dir:a}" | { shasum -a 256 2>/dev/null || sha256sum 2>/dev/null; } | cut -c1-8)"
  [[ -n "$suffix" ]] || suffix="default"
  print -r -- "$(_caw_state_dir)/${suffix}.${name}"
}

# key=value store in <hash>.state --------------------------------------------
_caw_state_get() {   # $1 = dir, $2 = key → prints value, non-zero if absent
  emulate -L zsh
  local f key="$2" line; f="$(_caw_state_file "$1" state)"
  [[ -r "$f" ]] || return 1
  while IFS= read -r line; do
    [[ "$line" == "$key="* ]] && { print -r -- "${line#*=}"; return 0; }
  done < "$f"
  return 1
}

_caw_state_set() {   # $1 = dir, $2 = key, $3 = value (atomic rewrite)
  emulate -L zsh
  local f key="$2" val="$3" tmp line found=0; f="$(_caw_state_file "$1" state)"
  mkdir -p "${f:h}" 2>/dev/null
  tmp="$f.tmp.$$"
  {
    [[ -r "$f" ]] && while IFS= read -r line; do
      if [[ "$line" == "$key="* ]]; then print -r -- "$key=$val"; found=1
      else print -r -- "$line"; fi
    done < "$f"
    (( found )) || print -r -- "$key=$val"
  } > "$tmp" 2>/dev/null && mv "$tmp" "$f" 2>/dev/null
}

_caw_state_del() {   # $1 = dir, $2 = key
  emulate -L zsh
  local f key="$2" tmp line; f="$(_caw_state_file "$1" state)"
  [[ -r "$f" ]] || return 0
  tmp="$f.tmp.$$"
  { while IFS= read -r line; do [[ "$line" == "$key="* ]] || print -r -- "$line"; done < "$f"; } \
    > "$tmp" 2>/dev/null && mv "$tmp" "$f" 2>/dev/null
}

# ----------------------------------------------------------------------------
# Post-open cooldown — the usage endpoint takes a few minutes to reflect a
# freshly opened window; during that lag _caw_session_active still reads
# "closed". We stamp last_open on every successful open and suppress re-firing
# for CLAUDE_AUTO_WINDOW_OPEN_COOLDOWN_SECONDS (default 900) so the daemon/cron
# doesn't fire a redundant starter while the endpoint catches up.
# ----------------------------------------------------------------------------
_caw_mark_opened() {
  emulate -L zsh
  _caw_state_set "$1" last_open "$(date +%s)"
}

_caw_recently_opened() {   # 0 if we opened a window within the cooldown
  emulate -L zsh
  local dir="$1" cooldown="${CLAUDE_AUTO_WINDOW_OPEN_COOLDOWN_SECONDS:-900}" t
  _caw_validate_uint CLAUDE_AUTO_WINDOW_OPEN_COOLDOWN_SECONDS "$cooldown" || return 1
  t="$(_caw_state_get "$dir" last_open)" || return 1
  [[ "$t" == <-> ]] || return 1
  (( $(date +%s) - t < cooldown ))
}

# ----------------------------------------------------------------------------
# Circuit breaker — stop an endless loop. Count consecutive opens that never
# register a window; after CLAUDE_AUTO_WINDOW_MAX_FAILURES (default 3) TRIP:
# notify + write the sentinel + refuse to run until --reset. The counter (in the
# state file) resets whenever a window is confirmed open. The sentinel is its own
# durable file so a cron job no-ops and a restarted daemon stays stopped.
# ----------------------------------------------------------------------------
_caw_breaker_count() {
  emulate -L zsh
  local n; n="$(_caw_state_get "$1" failcount)"; [[ "$n" == <-> ]] || n=0
  print -r -- "$n"
}

_caw_breaker_inc() {
  emulate -L zsh
  local n=$(( $(_caw_breaker_count "$1") + 1 ))
  _caw_state_set "$1" failcount "$n"
  print -r -- "$n"
}

_caw_breaker_reset() {   # window healthy → clear the counter
  emulate -L zsh
  _caw_state_del "$1" failcount
}

_caw_breaker_trip() {    # $2 = reason
  emulate -L zsh
  local f; f="$(_caw_state_file "$1" tripped)"
  mkdir -p "${f:h}" 2>/dev/null
  print -r -- "$(date '+%Y-%m-%d %H:%M:%S') $2" > "$f" 2>/dev/null
}

_caw_breaker_tripped() { emulate -L zsh; [[ -e "$(_caw_state_file "$1" tripped)" ]]; }
_caw_breaker_reason()  { emulate -L zsh; local f; f="$(_caw_state_file "$1" tripped)"; [[ -r "$f" ]] && cat "$f" 2>/dev/null; }
_caw_breaker_clear()   { emulate -L zsh; rm -f "$(_caw_state_file "$1" tripped)" 2>/dev/null; _caw_state_del "$1" failcount; }

# Fire an operator notification, if a hook command is configured. The message is
# passed both on stdin and as $CLAUDE_AUTO_WINDOW_MESSAGE, so hooks can use either
# (mail/ntfy read stdin; notify-send/osascript reference the env var).
_caw_notify() {
  emulate -L zsh
  local msg="$1"
  [[ -n "${CLAUDE_AUTO_WINDOW_NOTIFY_CMD:-}" ]] || return 0
  print -r -- "$msg" | CLAUDE_AUTO_WINDOW_MESSAGE="$msg" sh -c "$CLAUDE_AUTO_WINDOW_NOTIFY_CMD" 2>/dev/null
}

# ----------------------------------------------------------------------------
# The core: drive a real interactive Claude session inside a throwaway tmux
# session, wait for the reply, quit cleanly, tear it down.
# ----------------------------------------------------------------------------
# Wait until the expected reply token appears at least $count times in the pane.
# The prompt itself is echoed in Claude's input box, so it contributes one
# occurrence; the reply contributes another — hence the default threshold of 2.
#
# Also self-bootstraps the workspace-trust dialog: an interactive TTY (which a
# tmux pane is) shows "Do you trust the files in this folder?" on the first run
# in a new dir. We accept it by sending Enter (option 1, "Yes, proceed", is the
# highlighted default). Safe here because the starter dir is a dedicated empty
# directory the operator owns — override the keys with CLAUDE_AUTO_WINDOW_TRUST_KEYS.
_caw_wait_reply() {
  emulate -L zsh
  local sock="$1" sess="$2" timeout="$3" expect="$4" prompt="$5" count="${6:-1}"
  local deadline=$(( $(date +%s) + timeout )) pane body n trusted=0
  local -a trust_keys=( ${=CLAUDE_AUTO_WINDOW_TRUST_KEYS:-Enter} )

  # The prompt text (everything up to the expected token) is echoed in the input
  # box / rendered as the user turn — and it contains the expected token itself
  # (e.g. "…: OK."). Filter those lines out so we only match Claude's own reply.
  local prefix="${prompt%%${expect}*}"

  while (( $(date +%s) < deadline )); do
    # Session gone unexpectedly (crash / early exit) → give up.
    tmux -L "$sock" has-session -t "$sess" 2>/dev/null || return 2
    pane="$(tmux -L "$sock" capture-pane -p -t "$sess" 2>/dev/null)"

    # Accept the trust dialog once, if it appears (first run in a new dir).
    if (( ! trusted )) && \
       print -r -- "$pane" | grep -qiE 'trust the files in this folder|Do you trust|Yes, (proceed|I trust)' 2>/dev/null; then
      _caw_log INFO "Accepting workspace-trust dialog for the starter dir"
      tmux -L "$sock" send-keys -t "$sess" "${trust_keys[@]}" 2>/dev/null
      trusted=1
      sleep 1
      continue
    fi

    # Count the expected token only in lines that are NOT the prompt echo.
    if [[ -n "$prefix" ]]; then
      body="$(print -r -- "$pane" | grep -vF -- "$prefix" 2>/dev/null)"
    else
      body="$pane"
    fi
    n="$(print -r -- "$body" | grep -F -c -- "$expect" 2>/dev/null)"
    [[ "$n" == <-> ]] || n=0
    (( n >= count )) && return 0
    sleep 2
  done
  return 1
}

# Quit Claude gracefully (/exit), fall back to Ctrl-C, then kill the session.
_caw_quit_and_kill() {
  emulate -L zsh
  local sock="$1" sess="$2" i cur
  tmux -L "$sock" send-keys -t "$sess" -- "/exit" Enter 2>/dev/null
  for i in {1..8}; do
    sleep 1
    tmux -L "$sock" has-session -t "$sess" 2>/dev/null || return 0   # already gone
    cur="$(tmux -L "$sock" display-message -p -t "$sess" '#{pane_current_command}' 2>/dev/null)"
    case "$cur" in
      *zsh|*bash|*sh|-zsh|-bash) break ;;   # back to a shell → claude has exited
    esac
    (( i == 3 )) && tmux -L "$sock" send-keys -t "$sess" C-c C-c 2>/dev/null
  done
  tmux -L "$sock" kill-session -t "$sess" 2>/dev/null
}

# Self-heal an expired access token WITHOUT spending anything: launch a bare
# interactive claude in the same throwaway tmux — with NO prompt argument, so
# nothing is ever sent, no 5-hour window is opened, and no usage is spent — and
# wait for the stored credential to turn fresh. The CLI refreshes the access
# token (via the stored refresh token) on its first authenticated backend call
# at startup, typically within seconds; verified empirically 2026-07-20 (see
# AGENTS.md → Gotchas). Then tear the session down like a normal starter.
#   0 = token is fresh now, non-zero = it never turned fresh (most likely the
#   refresh token has expired too — >~3 days idle — which needs a manual login).
_caw_refresh_token() {
  emulate -L zsh
  local dir="$1" claude_bin starter_dir sock sess uuid pane
  local timeout="${CLAUDE_AUTO_WINDOW_REFRESH_TIMEOUT_SECONDS:-45}"
  _caw_validate_uint CLAUDE_AUTO_WINDOW_REFRESH_TIMEOUT_SECONDS "$timeout" || return $?
  claude_bin="$(_caw_resolve_claude_bin)" || return $?
  command -v tmux >/dev/null 2>&1 || { _caw_log ERROR "tmux not found on PATH"; return 2; }

  # Same stable starter dir + isolated socket as _caw_send_starter (one trust
  # entry, never the user's real tmux server).
  starter_dir="${CLAUDE_AUTO_WINDOW_STARTER_DIR:-${${TMPDIR:-/tmp}%/}/claude-auto-window-${UID}}"
  sock="${CLAUDE_AUTO_WINDOW_TMUX_SOCKET:-claude-auto-window}"
  mkdir -p "$starter_dir" || { _caw_log ERROR "cannot create starter dir: $starter_dir"; return 1; }
  sess="caw-refresh-$$-$(date +%s)-${RANDOM}"
  uuid="$(_caw_uuid)"

  # Same launch shape as the starter (API-key strip, profile pinning, LIGHT
  # context stripping, pinned session id) — minus the prompt and the model:
  # with nothing to send, there is nothing to bill and no model to pick.
  local -a launch
  launch=( env -u ANTHROPIC_API_KEY -u ANTHROPIC_AUTH_TOKEN CLAUDE_CODE_SKIP_PROMPT_HISTORY=1 )
  _caw_launch_profile_pinned && launch+=( "CLAUDE_CONFIG_DIR=$dir" )
  launch+=( "$claude_bin" )
  if [[ "${CLAUDE_AUTO_WINDOW_LIGHT:-1}" == 1 ]]; then
    launch+=( --safe-mode --tools "" --exclude-dynamic-system-prompt-sections )
  fi
  [[ -n "$uuid" ]] && launch+=( --session-id "$uuid" )
  local paneline="cd ${(q)starter_dir} && exec ${(j: :)${(@q)launch}}"

  _caw_log INFO "Token refresh: launching a bare claude session '$sess' (no prompt — nothing is sent or spent)"
  if ! tmux -L "$sock" new-session -d -s "$sess" -x 220 -y 50 "$paneline" 2>/dev/null; then
    _caw_log ERROR "failed to create tmux session"
    return 1
  fi

  {
    local deadline=$(( $(date +%s) + timeout )) trusted=0
    local -a trust_keys=( ${=CLAUDE_AUTO_WINDOW_TRUST_KEYS:-Enter} )
    while (( $(date +%s) < deadline )); do
      if _caw_resolve_token "$dir" >/dev/null; then
        _caw_log INFO "Access token refreshed by the launch"
        return 0
      fi
      tmux -L "$sock" has-session -t "$sess" 2>/dev/null || break   # crash/early exit
      # First run in a new starter dir: accept the trust dialog, same as the starter.
      if (( ! trusted )); then
        pane="$(tmux -L "$sock" capture-pane -p -t "$sess" 2>/dev/null)"
        if print -r -- "$pane" | grep -qiE 'trust the files in this folder|Do you trust|Yes, (proceed|I trust)' 2>/dev/null; then
          _caw_log INFO "Accepting workspace-trust dialog for the starter dir"
          tmux -L "$sock" send-keys -t "$sess" "${trust_keys[@]}" 2>/dev/null
          trusted=1
        fi
      fi
      sleep 2
    done
    _caw_log WARN "token did not refresh within ${timeout}s — the refresh token has likely expired too (>~3 days without Claude activity); a manual claude session / login is needed"
    return 1
  } always {
    _caw_quit_and_kill "$sock" "$sess"
    _caw_cleanup_transcript "$dir" "$uuid"
  }
}

# Send exactly one interactive starter.
#   $1 = check dir, $2 = show output (1/0), $3 = model (optional; "" = account
#   default / no --model). When $3 is omitted, CLAUDE_AUTO_WINDOW_MODEL is used
#   (default: the "haiku" alias — cheapest tier, always the latest version).
_caw_send_starter() {
  emulate -L zsh
  local dir="$1" show="${2:-0}" model
  if (( $# >= 3 )); then model="$3"; else model="${CLAUDE_AUTO_WINDOW_MODEL-haiku}"; fi
  local claude_bin prompt starter_dir sock sess expect count reply_timeout
  claude_bin="$(_caw_resolve_claude_bin)" || return $?

  command -v tmux >/dev/null 2>&1 || { _caw_log ERROR "tmux not found on PATH"; return 2; }

  prompt="${CLAUDE_AUTO_WINDOW_PROMPT:-Reply with exactly: OK.}"
  # Default to a stable per-user tmp dir: isolated from the work cwd, always
  # empty (transcripts are cleaned), and trusted exactly once — so it adds a
  # single ~/.claude.json trust entry, not one per run. Re-trusted automatically
  # if a reboot clears tmp. Override with --starter-dir for a fixed location.
  starter_dir="${CLAUDE_AUTO_WINDOW_STARTER_DIR:-${${TMPDIR:-/tmp}%/}/claude-auto-window-${UID}}"
  sock="${CLAUDE_AUTO_WINDOW_TMUX_SOCKET:-claude-auto-window}"
  expect="${CLAUDE_AUTO_WINDOW_EXPECT:-OK.}"
  count="${CLAUDE_AUTO_WINDOW_EXPECT_COUNT:-1}"   # prompt echo is filtered out
  reply_timeout="${CLAUDE_AUTO_WINDOW_REPLY_TIMEOUT_SECONDS:-120}"
  _caw_validate_uint CLAUDE_AUTO_WINDOW_EXPECT_COUNT "$count" || return $?
  _caw_validate_uint CLAUDE_AUTO_WINDOW_REPLY_TIMEOUT_SECONDS "$reply_timeout" || return $?

  mkdir -p "$starter_dir" || { _caw_log ERROR "cannot create starter dir: $starter_dir"; return 1; }

  # Unique tmux session name + a pinned session id we can delete afterward.
  sess="caw-$$-$(date +%s)-${RANDOM}"
  local uuid; uuid="$(_caw_uuid)"

  # Build the command line that runs inside the pane. Strip any API-key env so
  # the subscription OAuth login is used (an API key would bill separately and
  # not anchor the subscription window); skip prompt history. Pin the profile
  # only when explicitly selected.
  local -a launch
  launch=( env -u ANTHROPIC_API_KEY -u ANTHROPIC_AUTH_TOKEN CLAUDE_CODE_SKIP_PROMPT_HISTORY=1 )
  _caw_launch_profile_pinned && launch+=( "CLAUDE_CONFIG_DIR=$dir" )
  launch+=( "$claude_bin" )

  # Lightest possible context (opt out with CLAUDE_AUTO_WINDOW_LIGHT=0):
  #   --safe-mode   strip CLAUDE.md/memory, skills, hooks, MCP, plugins, agents,
  #                 output styles, themes, keybindings — OAuth auth still works.
  #   --tools ""    no built-in tool schemas in the context.
  #   --exclude-dynamic-system-prompt-sections  trim per-machine prompt sections.
  if [[ "${CLAUDE_AUTO_WINDOW_LIGHT:-1}" == 1 ]]; then
    launch+=( --safe-mode --tools "" --exclude-dynamic-system-prompt-sections )
  fi
  [[ -n "$uuid" ]] && launch+=( --session-id "$uuid" )
  [[ -n "$model" ]] && launch+=( --model "$model" )
  launch+=( "$prompt" )

  # Run claude directly as the pane's process (tmux execs it via `sh -c`) rather
  # than typing it into an interactive shell. That avoids a shell command-echo
  # in the pane — which would contain the prompt text ("…OK.") and defeat reply
  # detection. `exec` makes claude the pane's foreground process.
  local paneline="cd ${(q)starter_dir} && exec ${(j: :)${(@q)launch}}"

  _caw_log INFO "Opening tmux starter session '$sess' (socket '$sock', model '${model:-<account default>}')"
  if ! tmux -L "$sock" new-session -d -s "$sess" -x 220 -y 50 "$paneline" 2>/dev/null; then
    _caw_log ERROR "failed to create tmux session"
    return 1
  fi

  {
    if _caw_wait_reply "$sock" "$sess" "$reply_timeout" "$expect" "$prompt" "$count"; then
      _caw_log INFO "Claude replied ('$expect' x$count seen); closing session"
      (( show )) && tmux -L "$sock" capture-pane -p -t "$sess" 2>/dev/null
    else
      _caw_log WARN "no reply within ${reply_timeout}s (auth issue or a blocking prompt?)"
      (( show )) && tmux -L "$sock" capture-pane -p -t "$sess" 2>/dev/null
      return 4     # teardown happens in the always block below
    fi
  } always {
    _caw_quit_and_kill "$sock" "$sess"
    _caw_cleanup_transcript "$dir" "$uuid"
  }
  return 0
}

# Send a starter with the preferred (cheapest) model, falling back once to the
# account default model if that model got no reply — covers the rare case where
# the configured model/alias has been retired.
_caw_open_window() {
  emulate -L zsh
  local dir="$1" show="$2" rc primary
  primary="${CLAUDE_AUTO_WINDOW_MODEL-haiku}"
  _caw_send_starter "$dir" "$show" "$primary"; rc=$?
  if (( rc == 4 )) && [[ -n "$primary" ]]; then
    _caw_log WARN "no reply with model '$primary' (retired?); retrying on the account default model"
    _caw_send_starter "$dir" "$show" ""; rc=$?
  fi
  # Reply received ⇒ the request completed ⇒ a window is open. Stamp the cooldown
  # marker so the daemon doesn't re-open during the endpoint's propagation lag.
  (( rc == 0 )) && _caw_mark_opened "$dir"
  return $rc
}

# Best-effort confirmation that the window opened. The received reply is already
# proof the request completed (which is what opens the window); the usage
# endpoint can lag a few minutes before it reflects that. So this is purely
# informational and NEVER fails the run just because the endpoint hasn't caught
# up yet — a genuine no-reply failure is already returned by _caw_send_starter.
_caw_verify_started() {
  emulate -L zsh
  local dir="$1"
  local delay="${CLAUDE_AUTO_WINDOW_VERIFY_DELAY_SECONDS:-3}"
  _caw_validate_uint CLAUDE_AUTO_WINDOW_VERIFY_DELAY_SECONDS "$delay" || return 0
  (( delay > 0 )) && sleep "$delay"
  if _caw_session_active "$dir"; then
    _caw_log INFO "Five-hour window confirmed open for $dir"
  else
    _caw_log INFO "Starter reply received (request completed → window opened); the usage endpoint hasn't reflected it yet — it can lag a few minutes. Treating as success."
  fi
  return 0
}

# ============================================================================
# Public entry points
# ============================================================================

# Immediately fire one starter — no checks, no jitter.
claude-auto-window-run() {
  emulate -L zsh
  local dir lock rc verify="${CLAUDE_AUTO_WINDOW_VERIFY:-1}"
  dir="$(_caw_check_dir)"
  lock="$(_caw_acquire_lock "$dir")"; rc=$?
  (( rc == 75 )) && { _caw_log WARN "another claude-auto-window is running for $dir"; return 75; }
  (( rc != 0 )) && return "$rc"
  {
    # The only guard in --run: refuse if this account has NO 5-hour window at all
    # (usage-billed/API seat), since firing there just spends money for nothing.
    # Fail-open on everything else (active/closed/undetermined/token-expired) so
    # --run stays the "just do it" path (an expired access token is refreshed by
    # the launch itself). --force / CLAUDE_AUTO_WINDOW_FORCE=1 bypasses even this.
    if [[ "${CLAUDE_AUTO_WINDOW_FORCE:-0}" != 1 ]]; then
      _caw_session_active "$dir"; rc=$?
      if (( rc == 2 )); then
        _caw_log WARN "No 5-hour session window on this account ($dir) — refusing to fire (would spend money for no benefit). Use --force to override."
        return 70
      fi
    fi
    _caw_log INFO "run mode: firing one starter (no checks, no jitter)"
    _caw_open_window "$dir" 1 || return $?
    (( verify )) && _caw_verify_started "$dir"
  } always {
    _caw_release_lock "$lock"
  }
}

# Guarded cycle: check the window; only if none is open, jitter then fire.
claude-auto-window-once() {
  emulate -L zsh
  local dir lock rc
  local jitter_max="${CLAUDE_AUTO_WINDOW_JITTER_MAX_SECONDS:-180}"
  local jitter_min="${CLAUDE_AUTO_WINDOW_JITTER_MIN_SECONDS:-0}"
  _caw_validate_uint CLAUDE_AUTO_WINDOW_JITTER_MAX_SECONDS "$jitter_max" || return $?
  _caw_validate_uint CLAUDE_AUTO_WINDOW_JITTER_MIN_SECONDS "$jitter_min" || return $?
  (( jitter_min > jitter_max )) && jitter_max=$jitter_min   # clamp: keep min <= max
  dir="$(_caw_check_dir)"

  # If we already know when to act next — a stored resets_at that hasn't passed —
  # exit early WITHOUT hitting the endpoint. This is what lets a per-minute cron
  # cost almost nothing: it only fetches near expiry and during the post-open
  # confirm phase (when the stored resets_at is the old, now-past value).
  local _sr _sre
  if _sr="$(_caw_state_get "$dir" resets_at)" && [[ -n "$_sr" ]]; then
    _sre="$(_caw_iso_to_epoch "$_sr")"
    if [[ "$_sre" == <-> ]] && (( $(date +%s) < _sre )); then
      _caw_log INFO "Window open until $_sr — not due yet, exiting"
      return 0
    fi
  fi

  lock="$(_caw_acquire_lock "$dir")"; rc=$?
  (( rc == 75 )) && return 0     # someone else has it; nothing to do
  (( rc != 0 )) && return "$rc"

  {
    # Circuit breaker already tripped by a prior run → refuse to run until reset.
    # (No re-notify here; the notification fired when it tripped.)
    if _caw_breaker_tripped "$dir"; then
      _caw_log ERROR "Disabled by sentinel $(_caw_state_file "$dir" tripped) ($(_caw_breaker_reason "$dir")) — not running. Re-enable: claude-auto-window --reset"
      return 3
    fi

    _caw_session_active "$dir"; rc=$?
    if (( rc == 4 )); then
      # Access token expired (>8h without a claude launch). This is NOT the
      # rc-3 hard-fail — it's self-healable with zero spend: a bare claude
      # launch (no prompt) refreshes the token within seconds, so do that and
      # re-run the state check with the fresh token. Only if the refresh
      # launch itself fails do we fall through on rc 4 to firing a starter
      # blind — the send also refreshes, worst case it costs one tiny message
      # inside an already-open window, and if the refresh token has expired
      # too (>~3 days idle) the no-reply trips the circuit breaker.
      _caw_log INFO "Access token expired — self-healing with a bare claude launch, then re-checking"
      if _caw_refresh_token "$dir"; then
        _caw_session_active "$dir"; rc=$?
      else
        _caw_log WARN "Self-heal launch did not refresh the token; falling back to firing a starter blind"
      fi
    fi
    if (( rc == 0 )); then
      _caw_breaker_reset "$dir"         # window confirmed open → healthy, clear the counter
      _caw_log INFO "Window already open for $dir; nothing to do"
      return 0
    elif (( rc == 2 )); then
      _caw_log WARN "No 5-hour session window on this account ($dir) — nothing to keep open. If this is an API/usage-billed seat, don't run claude-auto-window (it would spend money for no benefit)."
      return 70                         # sentinel: no window on this account (not an error)
    elif (( rc == 3 )); then
      _caw_log ERROR "Could not determine window state for $dir"
      return 1
    elif (( rc == 4 )); then
      _caw_log INFO "Proceeding to fire the starter (its send refreshes the token; visibility returns next cycle)"
    fi

    # Endpoint-lag guard: the usage endpoint takes a few minutes to reflect a
    # freshly opened window, reading "closed" in the meantime. If we opened one
    # very recently, don't fire another starter conversation (the window is
    # already open — a repeat would just waste usage); wait for the endpoint.
    if _caw_recently_opened "$dir"; then
      _caw_log INFO "Opened a window recently; the usage endpoint may still be catching up — skipping"
      return 0
    fi

    # Window is closed. Guard against a spent weekly allowance before spending.
    local json; json="$(_caw_usage_json "$dir")"
    if _caw_weekly_exhausted "$json"; then
      _caw_log WARN "Weekly allowance exhausted; skipping starter"
      return 0
    fi

    # Jitter: we know we must open one, but wait a random min..max first so many
    # hosts / cron ticks don't stampede the endpoint at the same instant.
    local delay; delay=$(( jitter_min + $(_caw_random "$(( jitter_max - jitter_min ))") ))
    if (( delay > 0 )); then
      _caw_log INFO "Window closed; jittering ${delay}s (${jitter_min}-${jitter_max}s) before starter"
      sleep "$delay"
    fi

    # Normal activity during the jitter may already have opened the next window.
    _caw_session_active "$dir" && {
      _caw_breaker_reset "$dir"
      _caw_log INFO "Window opened during jitter (normal activity); no starter needed"
      return 0
    }
    json="$(_caw_usage_json "$dir")"
    _caw_weekly_exhausted "$json" && {
      _caw_log WARN "Weekly allowance became exhausted during jitter; skipping starter"
      return 0
    }

    # Circuit breaker: if the last few opens never registered a window (endpoint
    # never showed it open), stop instead of looping forever. Notify + trip.
    local fails max="${CLAUDE_AUTO_WINDOW_MAX_FAILURES:-3}"
    _caw_validate_uint CLAUDE_AUTO_WINDOW_MAX_FAILURES "$max" || return $?
    fails="$(_caw_breaker_count "$dir")"
    if (( fails >= max )); then
      local reason="${fails} consecutive opens did not register a 5-hour window"
      local sentinel; sentinel="$(_caw_state_file "$dir" tripped)"
      _caw_breaker_trip "$dir" "$reason"
      _caw_log ERROR "Circuit breaker TRIPPED for $dir: $reason. Disabled via sentinel: $sentinel. Re-enable with: claude-auto-window --reset (or: rm $sentinel)"
      _caw_notify "claude-auto-window DISABLED for $dir: $reason.

The tool has stopped itself to avoid a wasteful loop and will not run again until re-enabled.
Sentinel file: $sentinel
Re-enable with:  claude-auto-window --reset
(or simply:      rm $sentinel)"
      return 3
    fi

    _caw_breaker_inc "$dir" >/dev/null   # count this attempt; reset happens once a window is confirmed open
    _caw_open_window "$dir" 0 || return $?
    _caw_verify_started "$dir"
  } always {
    _caw_release_lock "$lock"
  }
}

# Daemon: run the guarded cycle, then sleep until the window expires instead of
# polling on a fixed cadence. When a window is open we know exactly when it ends
# (the stored resets_at), so we sleep until just after that — no polling in
# between. We only re-check at the fine interval to confirm a just-opened window
# (the endpoint lags a few minutes). A safety cap (MAX_SLEEP) bounds any single
# sleep.
claude-auto-window-daemon() {
  emulate -L zsh
  local dir; dir="$(_caw_check_dir)"
  local interval="${CLAUDE_AUTO_WINDOW_INTERVAL_SECONDS:-60}"
  _caw_validate_uint CLAUDE_AUTO_WINDOW_INTERVAL_SECONDS "$interval" || return $?
  (( interval >= 1 )) || { _caw_log ERROR "interval must be >= 1"; return 2; }
  local maxsleep="${CLAUDE_AUTO_WINDOW_MAX_SLEEP_SECONDS:-21600}"
  _caw_validate_uint CLAUDE_AUTO_WINDOW_MAX_SLEEP_SECONDS "$maxsleep" || return $?
  (( maxsleep < interval )) && maxsleep=$interval
  local buffer="${CLAUDE_AUTO_WINDOW_POST_EXPIRY_SECONDS:-5}"   # wake this long after expiry
  _caw_validate_uint CLAUDE_AUTO_WINDOW_POST_EXPIRY_SECONDS "$buffer" || return $?

  # Fail fast on persistent config errors so systemd's restart policy sees them.
  _caw_resolve_claude_bin >/dev/null || return $?

  local stop=0
  trap 'stop=1' INT TERM HUP

  _caw_log INFO "Daemon up: sleeps until window expiry (confirm poll ${interval}s, max sleep ${maxsleep}s), jitter ${CLAUDE_AUTO_WINDOW_JITTER_MIN_SECONDS:-0}-${CLAUDE_AUTO_WINDOW_JITTER_MAX_SECONDS:-180}s"
  local rc sleep_for now_s
  while (( ! stop )); do
    claude-auto-window-once; rc=$?
    if (( rc == 2 )); then
      _caw_log ERROR "Fatal configuration error; daemon exiting"
      return "$rc"
    elif (( rc == 70 )); then
      _caw_log WARN "This account has no 5-hour window to keep open — daemon exiting (nothing to do)."
      return 0                        # clean exit → systemd leaves it stopped, no restart loop
    elif (( rc == 3 )); then
      _caw_log ERROR "Circuit breaker tripped — daemon exiting to avoid a loop. Reset with: claude-auto-window --reset"
      return 0                        # clean exit; the persistent sentinel keeps it stopped across restarts
    elif (( rc != 0 && rc != 75 )); then
      _caw_log WARN "Cycle failed (status $rc); retrying in ${interval}s"
    fi

    # Read the stored resets_at (single source of truth). If it's in the future,
    # sleep until just AFTER expiry (+ buffer): the next check then sees it closed
    # and fires. Otherwise poll at the fine interval to confirm a freshly opened
    # window (the endpoint lags a few minutes before it reflects the new resets_at).
    sleep_for=$interval
    local sr sre
    sr="$(_caw_state_get "$dir" resets_at)"
    if [[ -n "$sr" ]]; then
      sre="$(_caw_iso_to_epoch "$sr")"
      if [[ "$sre" == <-> ]]; then
        now_s=$(date +%s)
        if (( sre > now_s )); then                          # future → sleep to expiry+buffer
          sleep_for=$(( sre + buffer - now_s ))
          (( sleep_for > maxsleep )) && sleep_for=$maxsleep # safety cap (clock drift / suspend)
          _caw_log INFO "Window open until $sr; sleeping ${sleep_for}s (wake ${buffer}s after expiry)"
        fi
      fi
    fi
    (( stop )) || sleep "$sleep_for" || true
  done
  _caw_log INFO "Daemon stopped"
  return 0
}

claude-auto-window-status() {
  emulate -L zsh
  _caw_status_line "$(_caw_check_dir)"
}

# ----------------------------------------------------------------------------
# Profile-name → config dir mapping for --profile.
# ----------------------------------------------------------------------------
_caw_apply_profile() {
  emulate -L zsh
  local name="$1"
  case "$name" in
    ""|default)  return 0 ;;                                            # let Claude resolve ~/.claude
    personal)    typeset -gx CLAUDE_AUTO_WINDOW_CONFIG_DIR="$HOME/.claude-personal" ;;
    work)        typeset -gx CLAUDE_AUTO_WINDOW_CONFIG_DIR="$HOME/.claude" ;;
    /*)          typeset -gx CLAUDE_AUTO_WINDOW_CONFIG_DIR="$name" ;;   # absolute path
    *)           _caw_log ERROR "unknown --profile '$name' (use default|personal|work|<abs path>)"; return 2 ;;
  esac
}

_caw_usage_text() {
  cat <<'USAGE'
claude-auto-window — keep a Claude five-hour window perpetually open (tmux-driven)

Usage:
  claude-auto-window [--once]            # check window; if closed, jitter + open (default)
  claude-auto-window --run               # open one now, no checks, no jitter
  claude-auto-window --daemon            # loop --once on a fixed interval
  claude-auto-window --status            # print current five-hour session state
  claude-auto-window --reset             # clear a tripped circuit breaker

Profile:
  --config-dir PATH        Explicit Claude profile dir (pins CLAUDE_CONFIG_DIR)
  --profile NAME           default | personal | work | <abs path>
                           (default = let Claude Code resolve ~/.claude)

Tuning (all also settable via CLAUDE_AUTO_WINDOW_* env, or a config file at
$XDG_CONFIG_HOME/claude-auto-window/config):
  --interval SEC           Daemon confirm-poll interval — how often to re-check
                           while waiting for the endpoint to reflect a just-opened
                           window. (Open windows are slept-through, not polled.)
                                                               Default: 60
  --post-expiry SEC        Daemon wakes this long after a window's expiry to fire
                           the next starter.                   Default: 5
  --max-sleep SEC          Cap on a single sleep (safety).     Default: 21600
  --jitter-max SEC         Upper bound of the random wait before firing. Keep
                           small on a single daemon for tight windows. Default: 180
  --jitter-min SEC         Lower bound of the random wait before firing. Default: 0
  --reply-timeout SEC      How long to wait for the reply.     Default: 120
  --verify-delay SEC       Delay before post-open verify.      Default: 3
  --prompt TEXT            Starter prompt. Default: "Reply with exactly: OK."
  --expect TEXT            Reply token to look for.            Default: "OK."
  --expect-count N         Reply occurrences required, after the prompt-echo
                           lines are filtered out.             Default: 1
  --model MODEL            Model alias or id. Default: haiku (cheapest tier,
                           alias tracks the latest version). "" = account
                           default. Falls back to the account default if the
                           chosen model has been retired.
  --starter-dir PATH       Working dir for the starter (isolated from the work
                           cwd). Default: $TMPDIR/claude-auto-window-<uid>.
  --claude-bin PATH        Absolute path to the claude executable.
  --tmux-socket NAME       Isolated tmux socket name (-L).     Default: claude-auto-window
  --log PATH               Also append logs here (stdout/stderr always on).
  --no-verify              Skip the post-open window verification.
  --quiet                  Suppress console output (log to --log file only).
                           Use for cron so it doesn't email on every run; rely
                           on --notify-cmd for the trip alert.
  --force                  With --run, fire even on an account that has no
                           5-hour window (bypasses the only --run safety check).
  --max-failures N         Consecutive opens that never register a window before
                           the circuit breaker trips + stops.        Default: 3
  --notify-cmd CMD         Shell command run when the breaker trips (message on
                           stdin and in $CLAUDE_AUTO_WINDOW_MESSAGE). e.g. a
                           notify-send / mail / ntfy / osascript one-liner.
  -h, --help               Show this help.
  -v, --version            Show version.

Source-able API:
  source ./claude-auto-window
  claude-auto-window-run | -once | -daemon | -status
USAGE
}

# ----------------------------------------------------------------------------
# CLI entrypoint — maps flags onto the CLAUDE_AUTO_WINDOW_* env the funcs read.
# ----------------------------------------------------------------------------
_caw_main() {
  emulate -L zsh
  setopt local_options

  # Load a config file first (lowest priority): fills CLAUDE_AUTO_WINDOW_* vars
  # not already set in the environment; CLI flags below override both.
  _caw_load_config

  local mode="once" mode_set=0 profile="" config_dir=""
  while (( $# )); do
    case "$1" in
      --run|--open-now)  [[ $mode_set == 1 && $mode != run ]] && { print -u2 "pick one mode"; return 2; }; mode=run; mode_set=1 ;;
      --once)            [[ $mode_set == 1 && $mode != once ]] && { print -u2 "pick one mode"; return 2; }; mode=once; mode_set=1 ;;
      --daemon)          [[ $mode_set == 1 && $mode != daemon ]] && { print -u2 "pick one mode"; return 2; }; mode=daemon; mode_set=1 ;;
      --status)          [[ $mode_set == 1 && $mode != status ]] && { print -u2 "pick one mode"; return 2; }; mode=status; mode_set=1 ;;
      --reset)           [[ $mode_set == 1 && $mode != reset ]] && { print -u2 "pick one mode"; return 2; }; mode=reset; mode_set=1 ;;
      --no-verify)       typeset -gx CLAUDE_AUTO_WINDOW_VERIFY=0 ;;
      --quiet)           typeset -gx CLAUDE_AUTO_WINDOW_QUIET=1 ;;
      --force)           typeset -gx CLAUDE_AUTO_WINDOW_FORCE=1 ;;
      --max-failures)    typeset -gx CLAUDE_AUTO_WINDOW_MAX_FAILURES="$2"; shift ;;
      --max-failures=*)  typeset -gx CLAUDE_AUTO_WINDOW_MAX_FAILURES="${1#*=}" ;;
      --notify-cmd)      typeset -gx CLAUDE_AUTO_WINDOW_NOTIFY_CMD="$2"; shift ;;
      --notify-cmd=*)    typeset -gx CLAUDE_AUTO_WINDOW_NOTIFY_CMD="${1#*=}" ;;
      --profile)         profile="$2"; shift ;;
      --profile=*)       profile="${1#*=}" ;;
      --config-dir)      config_dir="$2"; shift ;;
      --config-dir=*)    config_dir="${1#*=}" ;;
      --interval)        typeset -gx CLAUDE_AUTO_WINDOW_INTERVAL_SECONDS="$2"; shift ;;
      --interval=*)      typeset -gx CLAUDE_AUTO_WINDOW_INTERVAL_SECONDS="${1#*=}" ;;
      --max-sleep)       typeset -gx CLAUDE_AUTO_WINDOW_MAX_SLEEP_SECONDS="$2"; shift ;;
      --max-sleep=*)     typeset -gx CLAUDE_AUTO_WINDOW_MAX_SLEEP_SECONDS="${1#*=}" ;;
      --post-expiry)     typeset -gx CLAUDE_AUTO_WINDOW_POST_EXPIRY_SECONDS="$2"; shift ;;
      --post-expiry=*)   typeset -gx CLAUDE_AUTO_WINDOW_POST_EXPIRY_SECONDS="${1#*=}" ;;
      --jitter-max)      typeset -gx CLAUDE_AUTO_WINDOW_JITTER_MAX_SECONDS="$2"; shift ;;
      --jitter-max=*)    typeset -gx CLAUDE_AUTO_WINDOW_JITTER_MAX_SECONDS="${1#*=}" ;;
      --jitter-min)      typeset -gx CLAUDE_AUTO_WINDOW_JITTER_MIN_SECONDS="$2"; shift ;;
      --jitter-min=*)    typeset -gx CLAUDE_AUTO_WINDOW_JITTER_MIN_SECONDS="${1#*=}" ;;
      --reply-timeout)   typeset -gx CLAUDE_AUTO_WINDOW_REPLY_TIMEOUT_SECONDS="$2"; shift ;;
      --reply-timeout=*) typeset -gx CLAUDE_AUTO_WINDOW_REPLY_TIMEOUT_SECONDS="${1#*=}" ;;
      --verify-delay)    typeset -gx CLAUDE_AUTO_WINDOW_VERIFY_DELAY_SECONDS="$2"; shift ;;
      --verify-delay=*)  typeset -gx CLAUDE_AUTO_WINDOW_VERIFY_DELAY_SECONDS="${1#*=}" ;;
      --prompt)          typeset -gx CLAUDE_AUTO_WINDOW_PROMPT="$2"; shift ;;
      --prompt=*)        typeset -gx CLAUDE_AUTO_WINDOW_PROMPT="${1#*=}" ;;
      --expect)          typeset -gx CLAUDE_AUTO_WINDOW_EXPECT="$2"; shift ;;
      --expect=*)        typeset -gx CLAUDE_AUTO_WINDOW_EXPECT="${1#*=}" ;;
      --expect-count)    typeset -gx CLAUDE_AUTO_WINDOW_EXPECT_COUNT="$2"; shift ;;
      --expect-count=*)  typeset -gx CLAUDE_AUTO_WINDOW_EXPECT_COUNT="${1#*=}" ;;
      --model)           typeset -gx CLAUDE_AUTO_WINDOW_MODEL="$2"; shift ;;
      --model=*)         typeset -gx CLAUDE_AUTO_WINDOW_MODEL="${1#*=}" ;;
      --starter-dir)     typeset -gx CLAUDE_AUTO_WINDOW_STARTER_DIR="$2"; shift ;;
      --starter-dir=*)   typeset -gx CLAUDE_AUTO_WINDOW_STARTER_DIR="${1#*=}" ;;
      --claude-bin)      typeset -gx CLAUDE_AUTO_WINDOW_CLAUDE_BIN="$2"; shift ;;
      --claude-bin=*)    typeset -gx CLAUDE_AUTO_WINDOW_CLAUDE_BIN="${1#*=}" ;;
      --tmux-socket)     typeset -gx CLAUDE_AUTO_WINDOW_TMUX_SOCKET="$2"; shift ;;
      --tmux-socket=*)   typeset -gx CLAUDE_AUTO_WINDOW_TMUX_SOCKET="${1#*=}" ;;
      --log)             typeset -gx CLAUDE_AUTO_WINDOW_LOG="$2"; shift ;;
      --log=*)           typeset -gx CLAUDE_AUTO_WINDOW_LOG="${1#*=}" ;;
      -h|--help)         _caw_usage_text; return 0 ;;
      -v|--version)      print -r -- "claude-auto-window $CLAUDE_AUTO_WINDOW_VERSION"; return 0 ;;
      --)                shift; break ;;
      *)                 print -u2 "claude-auto-window: unknown argument: $1 (see --help)"; return 2 ;;
    esac
    shift
  done

  # --config-dir wins over --profile; both set the same env the funcs read.
  if [[ -n "$config_dir" ]]; then
    typeset -gx CLAUDE_AUTO_WINDOW_CONFIG_DIR="${config_dir%/}"
  elif [[ -n "$profile" ]]; then
    _caw_apply_profile "$profile" || return $?
  fi

  case "$mode" in
    run)    claude-auto-window-run ;;
    once)   claude-auto-window-once ;;
    daemon) claude-auto-window-daemon ;;
    status) claude-auto-window-status ;;
    reset)  claude-auto-window-reset ;;
  esac
}

# Keep a stable public alias for the default (guarded) cycle.
claude-auto-window() { claude-auto-window-once "$@"; }

# Run the CLI only when executed directly, not when sourced.
# ZSH_EVAL_CONTEXT contains ':file' when this file is being sourced.
case ":${ZSH_EVAL_CONTEXT:-}:" in
  *:file:*) ;;                       # sourced → just define functions
  *) _caw_main "$@"; exit $? ;;      # executed → run CLI
esac
